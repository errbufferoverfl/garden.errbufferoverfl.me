c/li\u003e\n\u003cli\u003e\u003ca\n  href=\"/bookmarks/flask-documentation/\"\n  rel=\"noopener\" class=\"internal-link\"\n  data-src=\"/bookmarks/flask-documentation/\"\u003eflask-documentation\u003c/a\u003e\u003c/li\u003e\n\u003cli\u003e\u003ca\n  href=\"/bookmarks/gold-mafia-episode-1-the-laundry-service/\"\n  rel=\"noopener\" class=\"internal-link\"\n  data-src=\"/bookmarks/gold-mafia-episode-1-the-laundry-service/\"\u003egold-mafia-episode-1-the-laundry-service\u003c/a\u003e\u003c/li\u003e\n\u003cli\u003e\u003ca\n  href=\"/bookmarks/oauth-20-dynamic-client-registration-protocol/\"\n  rel=\"noopener\" class=\"internal-link\"\n  data-src=\"/bookmarks/oauth-20-dynamic-client-registration-protocol/\"\u003eoauth-20-dynamic-client-registration-protocol\u003c/a\u003e\u003c/li\u003e\n\u003cli\u003e\u003ca\n  href=\"/bookmarks/police-are-not-primarily-crime-fighters-according-to-the-data/\"\n  rel=\"noopener\" class=\"internal-link\"\n  data-src=\"/bookmarks/police-are-not-primarily-crime-fighters-according-to-the-data/\"\u003epolice-are-not-primarily-crime-fighters-according-to-the-data\u003c/a\u003e\u003c/li\u003e\n\u003cli\u003e\u003ca\n  href=\"/bookmarks/python-patterns/\"\n  rel=\"noopener\" class=\"internal-link\"\n  data-src=\"/bookmarks/python-patterns/\"\u003epython-patterns\u003c/a\u003e\u003c/li\u003e\n\u003cli\u003e\u003ca\n  href=\"/bookmarks/refactoring-guru/\"\n  rel=\"noopener\" class=\"internal-link\"\n  data-src=\"/bookmarks/refactoring-guru/\"\u003erefactoring-guru\u003c/a\u003e\u003c/li\u003e\n\u003cli\u003e\u003ca\n  href=\"/bookmarks/restricting-ssh-sessions-for-ci-cd-with-gnu-rush/\"\n  rel=\"noopener\" class=\"internal-link\"\n  data-src=\"/bookmarks/restricting-ssh-sessions-for-ci-cd-with-gnu-rush/\"\u003erestricting-ssh-sessions-for-ci-cd-with-gnu-rush\u003c/a\u003e\u003c/li\u003e\n\u003cli\u003e\u003ca\n  href=\"/bookmarks/tracking-database-changes-in-flask-sqlalchemy-for-audit-logs/\"\n  rel=\"noopener\" class=\"internal-link\"\n  data-src=\"/bookmarks/tracking-database-changes-in-flask-sqlalchemy-for-audit-logs/\"\u003etracking-database-changes-in-flask-sqlalchemy-for-audit-logs\u003c/a\u003e\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003e%% End Waypoint %%\u003c/p\u003e\n"},{"title":"the antilibrary","date_published":"2023-05-28T00:00:00+10:00","date_modified":"2023-08-06T16:00:03+10:00","id":"https://garden.errbufferoverfl.me/the-antilibrary/","url":"https://garden.errbufferoverfl.me/the-antilibrary/","content_html":"\u003cblockquote\u003e\n\u003cp\u003ea scholar conscious of the power of [their] antilibrary is not concerned with treating knowledge as a property to possess or consume; rather [\u0026hellip;] how much you don’t know—and how to find out that information when you need it.\u003c/p\u003e\n\u003cp\u003e- Giovanni da Col, HAU: Journal of Ethnographic Theory\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003ch2 id=\"before-you-begin\"\u003eBefore you begin…\u003c/h2\u003e\n\u003cp\u003eThe notes and summaries included in these pages are snippets that remind me, or help me relate and explore high-level concepts. They aren\u0026rsquo;t a summary of the chapter or book! If you look through these notes and like the ideas, disagree with them, or you find yourself synthesising new ideas, I recommend you read the whole book!\u003c/p\u003e\n\u003ch3 id=\"up-next\"\u003eUp Next\u003c/h3\u003e\n\n\u003ch3 id=\"current\"\u003eCurrent\u003c/h3\u003e\n\u003cul class=\"section-ul\"\u003e\u003cli class=\"section-li\"\u003e\n        \u003cdiv class=\"section\"\u003e\n            \u003cdiv class=\"meta\"\u003e\u003cdiv class=\"article-img\"\u003e\n                    \u003cimg src=\"/imgs/ghost-work.png\" alt=\"This image is missing alt text.\" width=\"200vw\"\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n            \u003cdiv class=\"desc\" style=\"padding-left: 2em;\"\u003e\n                \u003ch3\u003e\u003ca href=\"/books/ghost-work/\" class=\"internal-link\" data-src=\"/books/ghost-work/\"\u003eGhost Work\u003c/a\u003e\u003c/h3\u003e\n                \u003cp style=\"padding-bottom: 1em; padding-top: 1em;\"\u003e\u0026ldquo;A startling exposé of the invisible human workforce that powers the web\u0026ndash;and how to bring it out of the shadows. Hidden beneath the surface of the internet, a new, stark reality is looming\u0026ndash;one that cuts to the very heart of our endless debates about the impact of AI.\u003c/p\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n        \u003cul class=\"tags\"\u003e\u003cli\u003e\u003ca href=\"/tags/book/\"\u003eBook\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/technology/\"\u003eTechnology\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/economics/\"\u003eEconomics\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/business/\"\u003eBusiness\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/labor/\"\u003eLabor\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/anthropology/\"\u003eAnthropology\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/politics/\"\u003ePolitics\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/sociology/\"\u003eSociology\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/artificial/\"\u003eArtificial\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/intelligence/\"\u003eIntelligence\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/non-fiction/\"\u003eNon-Fiction\u003c/a\u003e\u003c/li\u003e\u003c/ul\u003e\n    \u003c/li\u003e\u003c/ul\u003e\n\u003ch3 id=\"past\"\u003ePast\u003c/h3\u003e\n\u003cul class=\"section-ul\"\u003e\u003cli class=\"section-li\"\u003e\n        \u003cdiv class=\"section\"\u003e\n            \u003cdiv class=\"meta\"\u003e\u003cdiv class=\"article-img\"\u003e\n                    \u003cimg src=\"/imgs/the-feminist-and-the-sex-offender.png\" alt=\"This image is missing alt text.\" width=\"200vw\"\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n            \u003cdiv class=\"desc\" style=\"padding-left: 2em;\"\u003e\n                \u003ch3\u003e\u003ca href=\"/books/the-feminist-and-the-sex-offender/\" class=\"internal-link\" data-src=\"/books/the-feminist-and-the-sex-offender/\"\u003eThe Feminist and the Sex Offender\u003c/a\u003e\u003c/h3\u003e\n                \u003cp style=\"padding-bottom: 1em; padding-top: 1em;\"\u003eIn the era of Me Too and mass incarceration, The Feminist and the Sex Offender makes a powerful feminist case for accountability without punishment and sexual safety and pleasure without injustice.\u003c/p\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n        \u003cul class=\"tags\"\u003e\u003cli\u003e\u003ca href=\"/tags/book/\"\u003eBook\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/non-fiction/\"\u003eNon-Fiction\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/feminisim/\"\u003eFeminisim\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/politics/\"\u003ePolitics\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/philosophy/\"\u003ePhilosophy\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/theory/\"\u003eTheory\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/feminist-theory/\"\u003eFeminist Theory\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/gender/\"\u003eGender\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/social-justice/\"\u003eSocial Justice\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/academia/\"\u003eAcademia\u003c/a\u003e\u003c/li\u003e\u003c/ul\u003e\n    \u003c/li\u003e\u003cli class=\"section-li\"\u003e\n        \u003cdiv class=\"section\"\u003e\n            \u003cdiv class=\"meta\"\u003e\u003cdiv class=\"article-img\"\u003e\n                    \u003cimg src=\"/imgs/anarchic-agreements-a-field-guide-to-collective-organising.png\" alt=\"This image is missing alt text.\" width=\"200vw\"\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n            \u003cdiv class=\"desc\" style=\"padding-left: 2em;\"\u003e\n                \u003ch3\u003e\u003ca href=\"/books/anarchic-agreements-a-field-guide-to-collective-organising/\" class=\"internal-link\" data-src=\"/books/anarchic-agreements-a-field-guide-to-collective-organising/\"\u003eAnarchic Agreements, a Field Guide to Collective Organising\u003c/a\u003e\u003c/h3\u003e\n                \u003cp style=\"padding-bottom: 1em; padding-top: 1em;\"\u003eA new world is possible and not just in our hearts. Anarchic Agreements is a quintessential field guide for the revolution, answering the practical questions often left out of works of political theory and philosophy.\u003c/p\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n        \u003cul class=\"tags\"\u003e\u003cli\u003e\u003ca href=\"/tags/book/\"\u003eBook\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/non-fiction/\"\u003eNon-Fiction\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/political-science/\"\u003ePolitical Science\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/anarchy/\"\u003eAnarchy\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/anarchism/\"\u003eAnarchism\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/constitutions/\"\u003eConstitutions\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/history-and-theory/\"\u003eHistory and Theory\u003c/a\u003e\u003c/li\u003e\u003c/ul\u003e\n    \u003c/li\u003e\u003cli class=\"section-li\"\u003e\n        \u003cdiv class=\"section\"\u003e\n            \u003cdiv class=\"meta\"\u003e\u003cdiv class=\"article-img\"\u003e\n                    \u003cimg src=\"/imgs/lost-in-work-escaping-capitalism.png\" alt=\"This image is missing alt text.\" width=\"200vw\"\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n            \u003cdiv class=\"desc\" style=\"padding-left: 2em;\"\u003e\n                \u003ch3\u003e\u003ca href=\"/books/lost-in-work-escaping-capitalism/\" class=\"internal-link\" data-src=\"/books/lost-in-work-escaping-capitalism/\"\u003eLost in Work Escaping Capitalism\u003c/a\u003e\u003c/h3\u003e\n                \u003cp style=\"padding-bottom: 1em; padding-top: 1em;\"\u003e\u0026lsquo;Work hard, get paid.\u0026rsquo; It\u0026rsquo;s simple. Self-evident. But it\u0026rsquo;s also a lie—at least for most of us. For young people today, the old assumptions are crumbling; hard work in school no longer guarantees a secure, well-paying job in the future.\u003c/p\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n        \u003cul class=\"tags\"\u003e\u003cli\u003e\u003ca href=\"/tags/book/\"\u003eBook\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/non-fiction/\"\u003eNon-Fiction\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/politics/\"\u003ePolitics\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/sociology/\"\u003eSociology\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/economics/\"\u003eEconomics\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/history/\"\u003eHistory\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/philosophy/\"\u003ePhilosophy\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/feminism/\"\u003eFeminism\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/labor/\"\u003eLabor\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/theory/\"\u003eTheory\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/activism/\"\u003eActivism\u003c/a\u003e\u003c/li\u003e\u003c/ul\u003e\n    \u003c/li\u003e\u003cli class=\"section-li\"\u003e\n        \u003cdiv class=\"section\"\u003e\n            \u003cdiv class=\"meta\"\u003e\u003cdiv class=\"article-img\"\u003e\n                    \u003cimg src=\"/imgs/revolution-at-point-zero.png\" alt=\"This image is missing alt text.\" width=\"200vw\"\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n            \u003cdiv class=\"desc\" style=\"padding-left: 2em;\"\u003e\n                \u003ch3\u003e\u003ca href=\"/books/revolution-at-point-zero/\" class=\"internal-link\" data-src=\"/books/revolution-at-point-zero/\"\u003eRevolution at Point Zero\u003c/a\u003e\u003c/h3\u003e\n                \u003cp style=\"padding-bottom: 1em; padding-top: 1em;\"\u003eWritten between 1974 and 2016, Revolution at Point Zero collects four decades of research and theorising on the nature of housework, social reproduction, and women’s struggles on this terrain—to escape it, to better its conditions, to reconstruct it in ways that provide an alternative to capitalist relations.\u003c/p\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n        \u003cul class=\"tags\"\u003e\u003cli\u003e\u003ca href=\"/tags/book/\"\u003eBook\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/non-fiction/\"\u003eNon-Fiction\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/social-science/\"\u003eSocial Science\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/feminism/\"\u003eFeminism\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/nonfiction/\"\u003eNonfiction\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/politics/\"\u003ePolitics\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/philosophy/\"\u003ePhilosophy\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/theory/\"\u003eTheory\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/essays/\"\u003eEssays\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/gender/\"\u003eGender\u003c/a\u003e\u003c/li\u003e\u003c/ul\u003e\n    \u003c/li\u003e\u003c/ul\u003e\n\u003ch3 id=\"incomplete\"\u003eIncomplete\u003c/h3\u003e\n\u003cul class=\"section-ul\"\u003e\u003cli class=\"section-li\"\u003e\n        \u003cdiv class=\"section\"\u003e\n            \u003cdiv class=\"meta\"\u003e\u003cdiv class=\"article-img\"\u003e\n                    \u003cimg src=\"/imgs/expect-resistance-a-crimethinc-field-manual.png\" alt=\"This image is missing alt text.\" width=\"200vw\"\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n            \u003cdiv class=\"desc\" style=\"padding-left: 2em;\"\u003e\n                \u003ch3\u003e\u003ca href=\"/books/expect-resistance-a-crimethinc-field-manual/\" class=\"internal-link\" data-src=\"/books/expect-resistance-a-crimethinc-field-manual/\"\u003eExpect Resistance: A Crimethink Field Manual\u003c/a\u003e\u003c/h3\u003e\n                \u003cp style=\"padding-bottom: 1em; padding-top: 1em;\"\u003eExpect Resistance is not one but three books, each of which may be read as a complete work unto itself. The first book, printed in standard black ink, continues the inquiry into modern life and its discontents begun in Days of War, Nights of Love.\u003c/p\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n        \u003cul class=\"tags\"\u003e\u003cli\u003e\u003ca href=\"/tags/book/\"\u003eBook\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/political-science/\"\u003ePolitical Science\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/politics/\"\u003ePolitics\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/non-fiction/\"\u003eNon-Fiction\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/anarchism/\"\u003eAnarchism\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/philosophy/\"\u003ePhilosophy\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/activism/\"\u003eActivism\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/social-justice/\"\u003eSocial Justice\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/feminism/\"\u003eFeminism\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/counter-culture/\"\u003eCounter Culture\u003c/a\u003e\u003c/li\u003e\u003c/ul\u003e\n    \u003c/li\u003e\u003cli class=\"section-li\"\u003e\n        \u003cdiv class=\"section\"\u003e\n            \u003cdiv class=\"meta\"\u003e\u003cdiv class=\"article-img\"\u003e\n                    \u003cimg src=\"/imgs/the-age-of-surveillance-capitalism.png\" alt=\"This image is missing alt text.\" width=\"200vw\"\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n            \u003cdiv class=\"desc\" style=\"padding-left: 2em;\"\u003e\n                \u003ch3\u003e\u003ca href=\"/books/the-age-of-surveillance-capitalism/\" class=\"internal-link\" data-src=\"/books/the-age-of-surveillance-capitalism/\"\u003eThe Age of Surveillance Capitalism\u003c/a\u003e\u003c/h3\u003e\n                \u003cp style=\"padding-bottom: 1em; padding-top: 1em;\"\u003eThe challenges to humanity posed by the digital future, the first detailed examination of the unprecedented form of power called \u0026lsquo;surveillance capitalism,\u0026rsquo; and the quest by powerful corporations to predict and control us.\u003c/p\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n        \u003cul class=\"tags\"\u003e\u003cli\u003e\u003ca href=\"/tags/book/\"\u003eBook\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/non-fiction/\"\u003eNon-Fiction\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/politics/\"\u003ePolitics\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/economics/\"\u003eEconomics\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/technology/\"\u003eTechnology\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/business/\"\u003eBusiness\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/sociology/\"\u003eSociology\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"/tags/computers/\"\u003eComputers\u003c/a\u003e\u003c/li\u003e\u003c/ul\u003e\n    \u003c/li\u003e\u003c/ul\u003e\n"}]}